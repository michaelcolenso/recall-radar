{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "recall-radar",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-12",
  "workflows": [
    { "name": "ingestion", "binding": "INGESTION_WORKFLOW", "class_name": "IngestionWorkflow" },
    { "name": "enrichment", "binding": "ENRICHMENT_WORKFLOW", "class_name": "EnrichmentWorkflow" }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "PIPELINE_AGENT", "class_name": "PipelineAgent" }
    ]
  },
  "kv_namespaces": [
    { "binding": "PAGE_CACHE", "id": "local-page-cache", "preview_id": "local-page-cache" }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "recall_radar_db",
      "database_id": "local-recall-radar-db"
    }
  ],
  "vars": {
    "ADMIN_TOKEN": "change-me",
    "WORKERS_AI_MODEL_PRIMARY": "@cf/openai/gpt-oss-120b",
    "WORKERS_AI_MODEL_FALLBACK": "@cf/openai/gpt-oss-20b"
  },
  "triggers": {
    "crons": ["0 2 * * 1", "0 4 * * 1"]
  }
}
